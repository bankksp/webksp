{
  "name": "webksp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx api/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name=webksp",
    "start": "node api/index.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "html-react-parser": "^6.1.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-is": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-pageflip": "^2.0.3",
    "react-pdf": "^10.4.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "react-quill": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "react-pageflip": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250617.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wrangler": "^4.20.0"
  }
}
